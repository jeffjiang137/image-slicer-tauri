{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "电商设计助手",
  "version": "1.0.36",
  "identifier": "com.edy.image-slicer",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://127.0.0.1:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "电商设计助手",
        "width": 1360,
        "height": 860,
        "minWidth": 1120,
        "minHeight": 720,
        "resizable": true,
        "dragDropEnabled": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "../../../assets/app_icon.png",
      "../../../assets/app_icon.ico"
    ],
    "windows": {
      "webviewInstallMode": {
        "type": "downloadBootstrapper"
      }
    }
  }
}
